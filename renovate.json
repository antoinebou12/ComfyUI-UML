{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "Etc/UTC",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Dependabot updates Python (pyproject/uv); skip duplicates from Renovate.",
      "matchManagers": ["pep621", "pip_requirements", "pip_setup", "setup-cfg"],
      "enabled": false
    },
    {
      "description": "Dependabot updates web/js npm; skip duplicates from Renovate.",
      "matchManagers": ["npm"],
      "matchFileNames": ["web/js/package.json"],
      "enabled": false
    }
  ]
}
